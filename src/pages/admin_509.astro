---
import { getCollection } from 'astro:content';
import { TYPE_LABELS, TAG_LABELS, PROPERTY_LABELS } from '../data/tags-registry';

const allWorks = await getCollection('vykonani-roboty');

// Сортування: нові першими, ID = порядковий номер після сортування
const works = allWorks
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((w, i) => ({ ...w, id: i + 1 }));

const GITHUB_BASE = 'https://github.com/Vah509/elektro/edit/main/src/content/vykonani-roboty';
const SITE_BASE = 'https://elektromontazh.kiev.ua/vykonani-roboty';
---
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Адмін — Виконані роботи</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Geologica:wght@700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --accent: #0f5c30; --accent-b: rgba(15,92,48,0.22); --accent-f: rgba(15,92,48,0.07);
      --bg2: #f2f7f4; --muted: #6b7280; --head: #0f172a; --text: #111827;
      --div: rgba(15,92,48,0.12); --r: 8px;
      --ff: 'Geologica', sans-serif; --ffb: 'Manrope', sans-serif;
    }
    body { font-family: var(--ffb); color: var(--text); background: #f8faf9; font-size: 14px; }

    /* HEADER */
    .adm-header {
      background: var(--head); color: #fff; padding: 16px 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .adm-header h1 { font-family: var(--ff); font-size: 18px; font-weight: 700; }
    .adm-header span { font-size: 12px; opacity: .5; }

    /* STATS */
    .adm-stats {
      background: #fff; border-bottom: 1.5px solid var(--accent-b);
      padding: 16px 24px; display: flex; gap: 32px;
    }
    .adm-stat { display: flex; flex-direction: column; gap: 2px; }
    .adm-stat-val { font-family: var(--ff); font-size: 24px; font-weight: 700; color: var(--accent); }
    .adm-stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }

    /* SEARCH */
    .adm-search-wrap { padding: 16px 24px; background: #fff; border-bottom: 1px solid var(--div); }
    .adm-search {
      width: 100%; max-width: 400px; padding: 8px 14px;
      border: 1.5px solid var(--accent-b); border-radius: var(--r);
      font-family: var(--ffb); font-size: 14px; color: var(--text);
      outline: none;
    }
    .adm-search:focus { border-color: var(--accent); }

    /* TABLE */
    .adm-wrap { padding: 20px 24px; overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; background: #fff;
      border: 1.5px solid var(--accent-b); border-radius: var(--r); overflow: hidden; }
    thead { background: var(--bg2); }
    th {
      padding: 10px 14px; text-align: left; font-size: 11px; font-weight: 700;
      color: var(--muted); text-transform: uppercase; letter-spacing: .06em;
      border-bottom: 1.5px solid var(--accent-b); white-space: nowrap;
    }
    td { padding: 12px 14px; border-bottom: 1px solid var(--div); vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--accent-f); }

    /* CELLS */
    .cell-id {
      font-family: var(--ff); font-size: 18px; font-weight: 700;
      color: var(--accent); opacity: .4; width: 40px;
    }
    .cell-title { font-weight: 600; color: var(--head); min-width: 200px; }
    .cell-slug { font-family: monospace; font-size: 12px; color: var(--muted); white-space: nowrap; }
    .cell-date { font-size: 12px; color: var(--muted); white-space: nowrap; }
    .cell-photos { text-align: center; font-weight: 700; color: var(--accent); }

    /* PILLS */
    .pills { display: flex; flex-wrap: wrap; gap: 4px; min-width: 120px; }
    .pill {
      display: inline-block; border-radius: 20px; padding: 2px 8px;
      font-size: 11px; font-weight: 600; white-space: nowrap;
    }
    .pill-type { background: var(--accent-f); border: 1px solid var(--accent-b); color: var(--accent); }
    .pill-tag  { background: #fff; border: 1px solid var(--accent-b); color: var(--accent); }
    .pill-prop { background: transparent; border: 1px solid var(--div); color: var(--muted); }
    .pill-none { color: var(--div); font-size: 11px; }

    /* ACTIONS */
    .cell-actions { white-space: nowrap; }
    .btn-sm {
      display: inline-block; padding: 5px 10px; border-radius: 5px;
      font-size: 11px; font-weight: 600; text-decoration: none;
      font-family: var(--ffb); transition: opacity .2s; margin-right: 4px;
    }
    .btn-view { background: var(--accent); color: #fff; }
    .btn-edit { background: var(--head); color: #fff; }
    .btn-sm:hover { opacity: .8; }

    /* EMPTY */
    .adm-empty { padding: 40px; text-align: center; color: var(--muted); }
  </style>
</head>
<body>

<div class="adm-header">
  <h1>⚡ Виконані роботи — список</h1>
  <span>elektromontazh.kiev.ua · /admin_509/</span>
</div>

<!-- СТАТИСТИКА -->
<div class="adm-stats">
  <div class="adm-stat">
    <span class="adm-stat-val">{works.length}</span>
    <span class="adm-stat-label">Карточок</span>
  </div>
  {Object.keys(TYPE_LABELS).filter(t => works.some(w => w.data.types.includes(t))).map(t => (
    <div class="adm-stat">
      <span class="adm-stat-val">{works.filter(w => w.data.types.includes(t)).length}</span>
      <span class="adm-stat-label">{TYPE_LABELS[t]}</span>
    </div>
  ))}
</div>

<!-- ПОШУК -->
<div class="adm-search-wrap">
  <input
    type="search"
    class="adm-search"
    id="adm-search"
    placeholder="Пошук за назвою або slug..."
    autocomplete="off"
  />
</div>

<!-- ТАБЛИЦЯ -->
<div class="adm-wrap">
  <table id="adm-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Назва</th>
        <th>Slug</th>
        <th>Розділи</th>
        <th>Теги</th>
        <th>Властивості</th>
        <th>Фото</th>
        <th>Дата</th>
        <th>Дії</th>
      </tr>
    </thead>
    <tbody>
      {works.map(w => (
        <tr>
          <td class="cell-id">{w.id}</td>
          <td class="cell-title">{w.data.title}</td>
          <td class="cell-slug">{w.slug}</td>
          <td>
            <div class="pills">
              {w.data.types.map(t => (
                <span class="pill pill-type">{TYPE_LABELS[t] ?? t}</span>
              ))}
            </div>
          </td>
          <td>
            <div class="pills">
              {w.data.tags.length > 0
                ? w.data.tags.map(t => <span class="pill pill-tag">{TAG_LABELS[t] ?? t}</span>)
                : <span class="pill-none">—</span>
              }
            </div>
          </td>
          <td>
            <div class="pills">
              {w.data.properties && w.data.properties.length > 0
                ? w.data.properties.map(p => <span class="pill pill-prop">{PROPERTY_LABELS[p] ?? p}</span>)
                : <span class="pill-none">—</span>
              }
            </div>
          </td>
          <td class="cell-photos">{w.data.photos.length}</td>
          <td class="cell-date">
            {new Date(w.data.date).toLocaleDateString('uk-UA', { day:'2-digit', month:'2-digit', year:'numeric' })}
          </td>
          <td class="cell-actions">
            <a href={`${SITE_BASE}/${w.slug}/`} target="_blank" class="btn-sm btn-view">↗ Сайт</a>
            <a href={`${GITHUB_BASE}/${w.slug}.md`} target="_blank" class="btn-sm btn-edit">✎ GitHub</a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
  <div class="adm-empty" id="adm-empty" style="display:none">Нічого не знайдено</div>
</div>

<script is:inline>
  const search = document.getElementById('adm-search');
  const rows = document.querySelectorAll('#adm-table tbody tr');
  const empty = document.getElementById('adm-empty');

  search.addEventListener('input', () => {
    const q = search.value.toLowerCase().trim();
    let visible = 0;
    rows.forEach(row => {
      const text = row.textContent.toLowerCase();
      const show = !q || text.includes(q);
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    empty.style.display = visible === 0 ? 'block' : 'none';
  });
</script>

</body>
</html>
